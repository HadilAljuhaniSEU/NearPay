rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    // True when the request is from an authenticated Firebase user
    function isAuthed() {
      return request.auth != null;
    }

    // True when the authenticated user owns the given merchant document
    function ownsMerchant(merchantId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/merchants/$(merchantId)).data.ownerId
          == request.auth.uid;
    }

    // ─── users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    // ─── merchants ────────────────────────────────────────────────────────────
    match /merchants/{merchantId} {
      allow read:   if isAuthed() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthed() && resource.data.ownerId == request.auth.uid;
      allow delete: if false; // merchants are never deleted via client
    }

    // ─── branches ─────────────────────────────────────────────────────────────
    match /branches/{branchId} {
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);
    }

    // ─── customers ────────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);
    }

    // ─── debts ────────────────────────────────────────────────────────────────
    match /debts/{debtId} {
      // Merchant can do anything with their own debts
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);

      // Public approval: anyone with the approvalToken may read + update approval fields only
      allow read: if resource.data.approvalToken == request.query.approvalToken
                  || resource.data.paymentToken  == request.query.paymentToken;

      allow update: if
        // Approval action: only approvalStatus, status, updatedAt allowed
        (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['approvalStatus', 'status', 'updatedAt']))
        ||
        // Payment action: only remainingAmount, status, updatedAt allowed
        (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['remainingAmount', 'status', 'updatedAt']));
    }

    // ─── payments ─────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      // Merchant reads their own payments
      allow read: if ownsMerchant(resource.data.merchantId);

      // Anyone can create a payment (via public payment link)
      // The merchantId in the document is validated server-side via token matching
      allow create: if true;
    }

    // ─── trust_scores ─────────────────────────────────────────────────────────
    match /trust_scores/{docId} {
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);
    }

    // ─── analytics ────────────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);
    }

    // ─── notifications (reserved for FCM) ────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if ownsMerchant(resource.data.merchantId);
      allow create:      if ownsMerchant(request.resource.data.merchantId);
    }

    // ─── merchant_settings ────────────────────────────────────────────────────
    match /merchant_settings/{merchantId} {
      allow read, write: if ownsMerchant(merchantId);
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
